# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Test / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Prisma Client Python (generated by `prisma generate`)
app/prisma_client/

# Prisma engine cache
.prisma/

# Local databases / dumps
*.sqlite
*.sqlite3
*.db
*.dump

# Uploaded files (served via /uploads). Keep the directory, ignore contents.
app/uploads/*
!app/uploads/.gitkeep

# Logs
*.log

# OS / IDE (per-folder, in case this project is opened standalone)
.DS_Store
.vscode/
.idea/
