// Prisma is retained for schema management only (`prisma db push`,
// `prisma migrate`). Runtime DB access uses SQLAlchemy — see app/models/.
// No `generator client` block: we don't need the generated Python client.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeSide {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AccountType {
  LIVE
  DEMO
  PROP
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  PENDING
  ERROR
}

enum MarketType {
  STOCK
  FOREX
  COMMODITY
  CRYPTO
}

enum TransactionType {
  BUY
  SELL
}

enum ExpenseCategory {
  FOOD
  HOUSING
  TRANSPORT
  UTILITIES
  ENTERTAINMENT
  SHOPPING
  HEALTHCARE
  EDUCATION
  SUBSCRIPTIONS
  TRAVEL
  OTHER
}

enum InvestmentType {
  STOCK_IN
  STOCK_US
  ETF_IN
  ETF_US
  MUTUAL_FUND
  GOLD_ETF
  GOLD_SGB
  GOLD_DIGITAL
  GOLD_PHYSICAL
  BOND
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts         Account[]
  trades           Trade[]
  journals         DailyJournal[]
  strategies       Strategy[]
  connections      Connection[]
  financialProfile FinancialProfile?
  investments      Investment[]
  expenses         Expense[]

  @@map("users")
}

model FinancialProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  age                   Int?
  monthlyIncome         Decimal? @db.Decimal(18, 2)
  monthlyFamilyExpense  Decimal? @db.Decimal(18, 2)
  monthlySavings        Decimal? @db.Decimal(18, 2)
  currency              String   @default("USD")
  usdInrRate            Decimal? @db.Decimal(12, 4)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_profiles")
}

model Investment {
  id             String         @id @default(cuid())
  userId         String
  type           InvestmentType
  name           String
  symbol         String?
  quantity       Decimal        @db.Decimal(18, 8)
  avgCostPrice   Decimal        @db.Decimal(18, 4)
  currentPrice   Decimal?       @db.Decimal(18, 4)
  currency       String         @default("INR")
  purchaseDate   DateTime?      @db.Date
  maturityDate   DateTime?      @db.Date
  couponRate     Decimal?       @db.Decimal(6, 3)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions InvestmentTransaction[]

  @@index([userId])
  @@index([userId, type])
  @@map("investments")
}

model InvestmentTransaction {
  id               String          @id @default(cuid())
  userId           String
  investmentId     String
  type             TransactionType
  quantity         Decimal         @db.Decimal(18, 8)
  price            Decimal         @db.Decimal(18, 4)
  fees             Decimal         @default(0) @db.Decimal(18, 2)
  transactionDate  DateTime        @db.Date
  notes            String?
  createdAt        DateTime        @default(now())

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([investmentId])
  @@index([userId, transactionDate])
  @@map("investment_transactions")
}

model Account {
  id            String      @id @default(cuid())
  userId        String
  name          String
  brokerName    String?
  accountNumber String?
  type          AccountType @default(LIVE)
  balance       Decimal     @default(0) @db.Decimal(18, 2)
  currency      String      @default("USD")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId])
  @@map("accounts")
}

model Connection {
  id         String           @id @default(cuid())
  userId     String
  brokerName String
  status     ConnectionStatus @default(PENDING)
  metadata   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("connections")
}

model Strategy {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  entryCriteria Json     @default("[]")
  exitCriteria  Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId])
  @@map("strategies")
}

model Trade {
  id           String      @id @default(cuid())
  userId       String
  accountId    String
  strategyId   String?
  journalId    String?
  symbol       String
  side         TradeSide
  status       TradeStatus @default(CLOSED)
  quantity     Decimal     @db.Decimal(18, 8)
  entryPrice   Decimal     @db.Decimal(18, 8)
  exitPrice    Decimal?    @db.Decimal(18, 8)
  pnl          Decimal     @default(0) @db.Decimal(18, 2)
  commission   Decimal     @default(0) @db.Decimal(18, 2)
  currency     String      @default("USD")
  market       MarketType  @default(STOCK)
  notes        String?
  tags         String[]    @default([])
  isVerified   Boolean     @default(false)
  openedAt     DateTime
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  strategy    Strategy?         @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  journal     DailyJournal?     @relation(fields: [journalId], references: [id], onDelete: SetNull)
  attachments TradeAttachment[]

  @@index([userId, openedAt])
  @@index([userId, closedAt])
  @@index([accountId])
  @@map("trades")
}

model DailyJournal {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  notes     String?
  mood      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_journals")
}

model TradeAttachment {
  id        String   @id @default(cuid())
  tradeId   String
  userId    String
  url       String
  filename  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([userId])
  @@map("trade_attachments")
}

model Expense {
  id          String          @id @default(cuid())
  userId      String
  category    ExpenseCategory @default(OTHER)
  amount      Decimal         @db.Decimal(18, 2)
  currency    String          @default("INR")
  expenseDate DateTime        @db.Date
  description String?
  recurring   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expenseDate])
  @@index([userId, category])
  @@map("expenses")
}
